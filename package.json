{
  "name": "@themystic07/liveline-native",
  "version": "0.1.0",
  "type": "module",
  "description": "React Native Liveline-style real-time charts with Skia, Reanimated, candle mode, and multi-series support.",
  "keywords": [
    "react-native",
    "expo",
    "chart",
    "real-time",
    "skia",
    "reanimated",
    "candlestick",
    "ohlc",
    "multi-series"
  ],
  "license": "UNLICENSED",
  "author": "TheMystic07",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheMystic07/-Liveline-ReactNative.git"
  },
  "homepage": "https://github.com/TheMystic07/-Liveline-ReactNative#readme",
  "bugs": {
    "url": "https://github.com/TheMystic07/-Liveline-ReactNative/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=2.2.12",
    "expo-haptics": ">=15.0.8",
    "number-flow-react-native": ">=0.4.1",
    "react": ">=19",
    "react-native": ">=0.81",
    "react-native-gesture-handler": ">=2.28.0",
    "react-native-reanimated": ">=4.1.1"
  },
  "devDependencies": {
    "@shopify/react-native-skia": "2.2.12",
    "@types/react": "~19.1.0",
    "expo": "~54.0.33",
    "expo-haptics": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "number-flow-react-native": "^0.4.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tsup": "^8.5.1",
    "typescript": "~5.9.2"
  },
  "private": false
}
